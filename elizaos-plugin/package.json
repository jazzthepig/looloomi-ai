{
  "name": "@elizaos-plugins/plugin-cometcloud",
  "version": "0.1.0",
  "description": "CometCloud CIS (Crypto Intelligence Score) plugin for ElizaOS — institutional-grade crypto ratings, macro pulse, and exclusion screening for AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "keywords": [
    "elizaos",
    "eliza",
    "plugin",
    "crypto",
    "ai",
    "cis",
    "defi",
    "intelligence",
    "cometcloud",
    "ratings",
    "scoring",
    "agent"
  ],
  "author": "CometCloud AI <hi@cometcloud.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/looloomi-ai/elizaos-plugin-cometcloud"
  },
  "homepage": "https://looloomi.ai",
  "peerDependencies": {
    "@elizaos/core": "^0.1.0"
  },
  "devDependencies": {
    "@elizaos/core": "^0.1.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
